{
  "name": "sankofa-cli",
  "version": "0.1.1",
  "description": "Sankofa CLI — one command to scaffold, ship, and verify Sankofa across Flutter, React Native, Web, iOS, and Android. Includes Sankofa Deploy (OTA patches), keys, doctor, release, and patch flows.",
  "bin": {
    "sankofa": "./dist/index.js"
  },
  "scripts": {
    "build": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sankofa",
    "ota",
    "deploy",
    "code-push",
    "codepush",
    "flutter",
    "react-native",
    "expo",
    "mobile",
    "cli"
  ],
  "author": "Sankofa-HQ",
  "license": "MIT",
  "homepage": "https://sankofa.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sankofa-HQ/sankofa-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Sankofa-HQ/sankofa-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "form-data": "^4.0.0",
    "googleapis": "^130.0.0",
    "inquirer": "^9.2.0",
    "node-fetch": "^3.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
